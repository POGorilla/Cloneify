<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.proiect.spotifyclone.controller.AiPageController"
      spacing="14" style="-fx-padding: 18 18 12 18;">

    <Label text="AI Playlist"
           style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold;"/>

    <VBox spacing="6">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="promptField"
                       promptText="Describe your playlist..."
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 24; -fx-padding: 10 14; -fx-pref-height: 40;"/>

            <Button text="Generate" onAction="#onGenerate"
                    style="-fx-background-color: #1db954; -fx-background-radius: 24;
                           -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-padding: 8 18; -fx-pref-height: 40; -fx-cursor: hand;"/>

            <Button fx:id="saveAiPlaylistBtn" text="+" onAction="#onSaveAiPlaylist"
                    style="-fx-background-color: transparent;
                           -fx-border-color: #1db954; -fx-border-width: 2;
                           -fx-text-fill: #1db954; -fx-font-weight: bold; -fx-font-size: 16;
                           -fx-background-radius: 20; -fx-border-radius: 20;
                           -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;"/>
        </HBox>

        <Label fx:id="statusLabel" text="" wrapText="true"
               style="-fx-text-fill: #b3b3b3; -fx-font-size: 12; -fx-padding: 0 0 0 8;"/>
    </VBox>

    <Label fx:id="playlistNameLabel" text=""
           style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>

    <ScrollPane fitToWidth="true"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <content>
            <VBox fx:id="resultsContainer" spacing="6" style="-fx-padding: 6;"/>
        </content>
    </ScrollPane>

</VBox>

