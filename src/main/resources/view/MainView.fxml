<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.proiect.spotifyclone.controller.MainController"
            style="-fx-background-color: transparent;">

    <BorderPane fx:id="mainContainer"
                AnchorPane.topAnchor="10.0" AnchorPane.rightAnchor="10.0"
                AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0"
                style="-fx-background-color: #121212;
                       -fx-background-radius: 30; -fx-border-radius: 30;
                       -fx-background-insets: 0; -fx-border-insets: 0;
                       -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 0);">

        <left>
            <VBox fx:id="sidebar" spacing="15"
                  style="-fx-background-color: #000000; -fx-pref-width: 240; -fx-padding: 20;
                         -fx-background-radius: 30 0 0 30;">
                <Label text="Cloneify" textFill="WHITE">
                    <font><Font name="System Bold" size="24.0"/></font>
                </Label>

                <Region prefHeight="20"/>

                <Label text="MENU" textFill="#b3b3b3"><font><Font size="11.0"/></font></Label>

                <Button text="🏠  Home" onAction="#onHomeClick"
                        textFill="WHITE" alignment="BASELINE_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-font-size: 14; -fx-cursor: hand;"/>

                <Button text="🔍  Search" onAction="#onSearchNavClick"
                        textFill="WHITE" alignment="BASELINE_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-font-size: 14; -fx-cursor: hand;"/>

                <Button text="🤖 Smart Playlist" onAction="#onAiNavClick"
                        textFill="WHITE" alignment="BASELINE_LEFT" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-font-size: 14; -fx-cursor: hand;"/>

                <Region prefHeight="20"/>

                <Label text="PLAYLISTS" textFill="#b3b3b3"><font><Font size="11.0"/></font></Label>

                <VBox spacing="10">
                    <Button onAction="#onCreatePlaylist"
                            text="➕  Create Playlist"
                            textFill="WHITE"
                            alignment="BASELINE_LEFT"
                            maxWidth="Infinity"
                            style="-fx-background-color: #282828; -fx-background-radius: 8; -fx-padding: 10 12; -fx-cursor: hand;"/>

                    <ListView fx:id="playlistsList"
                              VBox.vgrow="ALWAYS"
                              style="-fx-background-color: transparent; -fx-control-inner-background: transparent;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #181818; -fx-padding: 10; -fx-background-radius: 30;">
                    <Circle fx:id="avatar" radius="15" fill="#535353"/>
                    <Label text="My Profile" textFill="WHITE" style="-fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </left>

        <center>
            <StackPane fx:id="pageContainer"
                       style="-fx-background-color: transparent; -fx-padding: 20;">
            </StackPane>
        </center>

        <bottom>
            <VBox style="-fx-background-color: #181818; -fx-border-color: #282828; -fx-border-width: 1 0 0 0;
                         -fx-background-radius: 0 0 30 30;">
                <Slider fx:id="progressSlider" min="0" value="0"
                        style="-fx-padding: 0 0 -5 0; -fx-cursor: hand;"/>

                <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10 20;">
                    <HBox alignment="CENTER_LEFT" spacing="15" minWidth="200">
                        <StackPane fx:id="nowPlayingCoverContainer"
                                   style="-fx-background-color: #282828; -fx-pref-width: 50; -fx-pref-height: 50;">
                            <Label text="🎵" textFill="#b3b3b3"/>
                        </StackPane>
                        <VBox alignment="CENTER_LEFT">
                            <Label fx:id="currentSongLabel" text="Nothing Playing" textFill="WHITE"
                                   style="-fx-font-weight: bold;"/>
                            <Label fx:id="currentAuthorLabel" text="Select a song" textFill="#b3b3b3"
                                   style="-fx-font-size: 11;"/>
                        </VBox>

                        <Button fx:id="addCurrentToPlaylistBtn"
                                text="➕"
                                onAction="#onAddCurrentToPlaylist"
                                style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-font-size: 16; -fx-cursor: hand;"/>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox alignment="CENTER" spacing="20">
                        <Button text="⏮" textFill="WHITE"
                                style="-fx-background-color: transparent; -fx-font-size: 18;"/>
                        <Button fx:id="playPauseButton" text="▶" onAction="#onPlayPauseClick" textFill="BLACK"
                                style="-fx-background-color: WHITE; -fx-background-radius: 50;
                                       -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;"/>
                        <Button text="⏭" textFill="WHITE"
                                style="-fx-background-color: transparent; -fx-font-size: 18;"/>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox alignment="CENTER_RIGHT" spacing="10" minWidth="200">
                        <Label text="🔊" textFill="#b3b3b3"/>
                        <Slider fx:id="volumeSlider" min="0" max="100" value="50"
                                style="-fx-pref-width: 100; -fx-cursor: hand;"/>
                    </HBox>
                </HBox>
            </VBox>
        </bottom>

    </BorderPane>

    <HBox alignment="CENTER_RIGHT" spacing="10"
          AnchorPane.topAnchor="24.0" AnchorPane.rightAnchor="28.0"
          style="-fx-background-color: transparent;">
        <Button text="_" onAction="#onMinimizeClick"
                style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-font-size: 14; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="✕" onAction="#onCloseClick"
                style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-font-size: 14; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

</AnchorPane>
