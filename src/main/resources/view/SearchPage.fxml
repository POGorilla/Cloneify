<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.proiect.spotifyclone.controller.SearchPageController"
      spacing="16" style="-fx-background-color: #121212; -fx-padding: 20; -fx-background-radius: 0 30 0 0;">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #ffffff; -fx-background-radius: 50; -fx-padding: 5 15;"
              HBox.hgrow="ALWAYS" maxWidth="520">
            <Label text="🔍" textFill="BLACK"/>
            <TextField fx:id="searchField" promptText="What do you want to listen to?"
                       style="-fx-background-color: transparent; -fx-text-fill: black;"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <Button text="Search" onAction="#onSearchClick"
                style="-fx-background-color: #1DB954; -fx-text-fill: white; -fx-background-radius: 50; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <Label text="Songs" textFill="WHITE">
        <font><Font name="System Bold" size="20.0"/></font>
    </Label>

    <ScrollPane fitToWidth="true" style="-fx-background: #121212; -fx-background-color: transparent;">
        <VBox fx:id="resultsContainer" spacing="5" style="-fx-background-color: #121212;"/>
    </ScrollPane>

</VBox>
